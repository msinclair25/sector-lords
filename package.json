{
  "name": "chaosoverlords",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:itch": "tsc && vite build --base ./ --mode itch",
    "zip:itch": "npm run build:itch && node scripts/zip-itch.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler pages deploy dist --project-name sector-lords",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name sector-lords --branch preview",
    "check:live": "node scripts/check-live.mjs",
    "check:trace": "node scripts/analyze-trace.mjs",
    "smoke:import": "node scripts/smoke-import.mjs"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "playwright": "^1.49.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "phaser": "^4.2.1",
    "three": "^0.185.1"
  }
}
